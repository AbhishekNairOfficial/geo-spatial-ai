# ------------------------------------------------------------
# LLM provider
# ------------------------------------------------------------
# Which provider the server uses. Either `openai` or `azure-openai`.
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI (used when LLM_PROVIDER=azure-openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ------------------------------------------------------------
# Map
# ------------------------------------------------------------
# Public Mapbox token (exposed to the browser).
NEXT_PUBLIC_MAPBOX_TOKEN=

# ------------------------------------------------------------
# Data provider
# ------------------------------------------------------------
# `static` uses a bundled sample dataset. `kaggle` uses the build-time
# ingested Kaggle dataset. Default to static so local dev works without
# Kaggle credentials.
DATA_PROVIDER=static

# Kaggle build-time ingestion (only required when DATA_PROVIDER=kaggle).
# See README for how to get KAGGLE_USERNAME / KAGGLE_KEY from
# https://www.kaggle.com/settings -> API -> Create New Token.
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional (Vercel / server): public origin used to load large kaggle JSON/GeoJSON
# over HTTP instead of the serverless bundle. Set to your production URL, e.g.
# https://your-app.vercel.app or https://yourdomain.com (no trailing slash).
# KAGGLE_PUBLIC_ORIGIN=
# Example A — world / country (choropleth)
# KAGGLE_DATASET=saurabhbadole/life-expectancy-based-on-geographic-locations
# KAGGLE_FILE=Life Expectancy Data.csv
# KAGGLE_GEO_MODE=country
# KAGGLE_COUNTRY_COL=Country
# KAGGLE_METRIC=Life expectancy

# Example B — US IRS ZIP (ZCTA) + Census TIGER (default when dataset is IRS below)
KAGGLE_DATASET=irs/individual-income-tax-statistics
KAGGLE_FILE=2014.csv
# Optional: defaults to us_zip for this dataset
KAGGLE_GEO_MODE=us_zip
KAGGLE_METRIC=N1
# First build downloads Census cb_2020_us_zcta520_500k.zip (~64MB); set to skip download:
# ZCTA_LOCAL_PATH=/absolute/path/to/cb_2020_us_zcta520_500k.zip
# ZCTA_TIGER_URL=https://www2.census.gov/geo/tiger/GENZ2020/shp/cb_2020_us_zcta520_500k.zip

# Used only when KAGGLE_GEO_MODE=latlon
KAGGLE_LAT_COL=lat
KAGGLE_LON_COL=lon
